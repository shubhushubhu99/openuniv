# OpenUniverse Backend Configuration
# Copy this file to .env and fill in your actual values

# Database Configuration
DATABASE_HOST=localhost
DATABASE_NAME=openuniverse
DATABASE_USER=root
DATABASE_PASSWORD=

# Application Settings
APP_ENV=development
APP_DEBUG=true
APP_LOG_LEVEL=debug

# Email Configuration (for future use)
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@openuniverse.com

# Session Configuration
SESSION_LIFETIME=120

# API Settings
API_RATE_LIMIT=60
API_RATE_WINDOW=60

# Security
JWT_SECRET=your-super-secret-jwt-key-change-this
PASSWORD_HASH_COST=12
